<?xml version="1.0" encoding="utf-8"?>
<!--
  =========================================================================
  EQ Dashboard V2 — IIS web.config
  =========================================================================
  部署步驟：
    1. 確認 appsettings.json (或 appsettings.Production.json) 內的
       ConnectionStrings:GenAI 已是正式 DB 連線字串
       (本 web.config 已不再寫連線字串，預設由 appsettings 提供)
    2. dotnet publish -c Release -o publish
    3. 把 publish/ 整包丟到 IIS (例如 C:\inetpub\wwwroot\GenAI_TEST)
    4. IIS Manager 對該目錄右鍵 → 轉換為應用程式 (Convert to Application)
    5. 確認 App Pool 的 .NET CLR 版本 = "無受控碼 (No Managed Code)"
    6. 根據下方「設定區 B 登入模式」決定登入方式 (預設 = 純 Windows 自動偵測)
    7. iisreset

  ⚠️ 注意：若用 ASPNETCORE_ENVIRONMENT=Production，Program.cs startup guard 會檢查：
       - appsettings.json 的連線字串不可含 Password=test / Password=password
       - Auth:TestAccounts:Enabled 必須 false
       - Auth:EnableEmergencyAdmin 必須 false
       - Auth:Ldap:Enabled=true 時 Server 不可是 placeholder
     違反任一條 → 啟動會被擋下並印出 log。請對應改 appsettings.json 或
     appsettings.Production.json，再重新發布。

  ⭐ IIS 認證 (Windows 自動登入)：
    本 web.config **故意不寫** <security><authentication>...</authentication></security>
    這段，因為大多數企業 IIS 的 applicationHost.config 把它鎖在 server level
    (overrideModeDefault="Deny")，app 層級設定會直接觸發 HTTP 500.19。

    請改在 IIS Manager 點選此 App → Authentication 面板手動開啟：
      ✓ Anonymous Authentication  = Enabled
      ✓ Windows Authentication    = Enabled
      ✗ Basic Authentication      = Disabled (建議)
    Windows Authentication 內部的 Providers 建議：
      1. Negotiate   (Kerberos 優先，自動 fallback NTLM)
      2. NTLM

    瀏覽器若彈出帳密對話框 (不會自動帶入桌機 Windows 帳號)：
      → 是因為瀏覽器沒把這個網址列為「近端內部網路」(Local Intranet Zone)
      → Edge / IE：設定 → 隱私權與安全性 → 安全性 → 信任的網站 / 近端內部網路
                  → 加入 http://p58esiap12 (或實際主機名)
      → 並勾選「自動以目前的使用者名稱及密碼登入」
      → 一次設定後，之後開網頁就會自動帶入 Windows 帳號、不再跳對話框
      → 大型部署可用 GPO 統一推送 IE/Edge 的 Intranet Zone 設定

    若上述設定 IIS 因權限鎖死無法在 App 層級修改，請 IIS 管理員執行解鎖：
      %systemroot%\System32\inetsrv\appcmd unlock config -section:system.webServer/security/authentication/anonymousAuthentication
      %systemroot%\System32\inetsrv\appcmd unlock config -section:system.webServer/security/authentication/windowsAuthentication
-->
<configuration>

  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <aspNetCore processPath="dotnet"
                  arguments=".\GenAI.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">

        <environmentVariables>

          <!-- 環境名稱：Production 會觸發 Program.cs 的 startup guard，擋弱密碼/測試帳號/LDAP placeholder -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />

          <!-- ====================================================================
               Hosting__RequireHttps
               ====================================================================
               true  → 強制 HTTPS：UseHttpsRedirection + Cookie 帶 Secure flag
                       適用：站台有正式 HTTPS 憑證、走 https:// 訪問
               false → 允許 HTTP：不重定向 + Cookie 不帶 Secure
                       適用：IIS HTTP 站台 (例如 http://p58esiap12/GenAI_TEST/)
                       ⚠️ 若漏設 false 而站台是 HTTP：
                           - Cookie 有 Secure flag → 瀏覽器不會在 HTTP 送回
                           - 每個 request 都被視為未登入
                           - 看起來就是「登入後立刻被踢回登入頁」
               appsettings.Production.json 預設 false 對應內網 HTTP IIS。
               若 IIS 已上 HTTPS，把下面這條改 value="true"。
               ==================================================================== -->
          <environmentVariable name="Hosting__RequireHttps" value="false" />

          <!-- ====================================================================
               設定區 A：資料庫連線字串（選用：本檔預設不設定，由 appsettings.json 提供）
               ====================================================================
               目前連線字串走 appsettings.json 的 ConnectionStrings:GenAI，
               本檔不需要任何 ConnectionStrings__GenAI 條目，留空即可。

               何時才需要在這裡覆寫？
                 - 不同部署環境想用不同 DB（e.g. GenAI_TEST 接測試庫、
                   GenAI_PROD 接正式庫），且不想為每個環境改 appsettings.json
                 - 想讓密碼不出現在 source control 的 appsettings.json

               若要用，取消下方註解並改值即可（會覆寫 appsettings.json 的同名設定）：
          <environmentVariable name="ConnectionStrings__GenAI"
                               value="Data Source=...;Initial Catalog=GenAI;Integrated Security=True;TrustServerCertificate=True;" />

               提醒：
                 - 若用 SQL Server 帳密驗證，密碼為平文 → 有檔案存取權限的人都看得到
                 - 更安全的替代方案（任挑一個）：
                   * SQL Server Windows 整合驗證 (Integrated Security=True) — 不需密碼
                   * IIS Manager → App Pool → 進階設定 → 環境變數（不寫在 web.config）
                   * aspnet_regiis.exe -pef 用 DPAPI 加密本段（適用 <connectionStrings>）
               ==================================================================== -->

          <!-- ====================================================================
               設定區 B：登入模式選擇
               ====================================================================
               4 個旗標的組合決定能用哪種登入：

               旗標                              說明
               ─────────────────────────────────  ─────────────────────────────────
               Auth__AllowManualLogin            顯示「手動輸入」tab
               Auth__Ldap__Enabled               手動輸入時走 LDAP 驗證
               Auth__TestAccounts__Enabled       測試帳號 (admin/admin 等) 可登入
               Auth__EnableEmergencyAdmin        admin 不檢密碼救援通道 (極危險)

               常用組合 →

               【B1 純 Windows 自動偵測】(正式上線推薦)
                 AllowManualLogin=false / Ldap=任意 / TestAccounts=false / Emergency=false

               【B2 Windows + AD 手動帳密】(LDAP 已設好的中型部署)
                 AllowManualLogin=true / Ldap=true / TestAccounts=false / Emergency=false

               【B3 Windows + 測試帳號】(LDAP 未就緒但已上 IIS 測試)
                 AllowManualLogin=true / Ldap=false / TestAccounts=true / Emergency=false

               【B4 全開】(僅開發測試環境)
                 AllowManualLogin=true / Ldap=true / TestAccounts=true / Emergency=可選

               下面是【B1 純 Windows 自動偵測】範例。要改其他模式就改下面 4 條值。
               (注意：值為 "true"/"false" 字串，大小寫不敏感)
               ==================================================================== -->

          <environmentVariable name="Auth__AllowManualLogin"          value="false" />
          <environmentVariable name="Auth__Ldap__Enabled"             value="false" />
          <environmentVariable name="Auth__TestAccounts__Enabled"     value="false" />
          <environmentVariable name="Auth__EnableEmergencyAdmin"      value="false" />

          <!-- ====================================================================
               設定區 C：LDAP 細部設定 (僅當 Auth__Ldap__Enabled=true 才用得到)
               ==================================================================== -->
          <!--
          <environmentVariable name="Auth__Ldap__Server"               value="ldap.your-domain.com" />
          <environmentVariable name="Auth__Ldap__Port"                 value="389" />
          <environmentVariable name="Auth__Ldap__UseSsl"               value="true" />
          <environmentVariable name="Auth__Ldap__BindDomain"           value="UMC" />
          <environmentVariable name="Auth__Ldap__UserPrincipalSuffix"  value="@your-domain.com" />
          -->

          <!-- ====================================================================
               設定區 D：Windows 域名前綴 (預設 UMC，若 AD 域名不同請覆寫)
                 取自 User.Identity.Name → 例如 "UMC\41856" 會剝掉 "UMC\" 取 "41856"
               ==================================================================== -->
          <!--
          <environmentVariable name="Auth__WindowsDomainStripPrefix"   value="UMC" />
          -->

        </environmentVariables>
      </aspNetCore>

      <!-- ⚠️ 本 web.config 故意不寫 <security><authentication> 區段 —
           多數企業 IIS 把它鎖在 server level，app 層級設定會 HTTP 500.19。
           請改在 IIS Manager → Authentication 面板手動 Enable Anonymous + Windows。
           詳見檔頂註解。
       -->
      <security>
        <!-- 單一 request body 上限 50 MB (這個 section 沒被鎖，可以在 app 層級設) -->
        <requestFiltering>
          <requestLimits maxAllowedContentLength="52428800" />
        </requestFiltering>
      </security>

      <!-- 移除洩漏 IIS 版本的 X-Powered-By；HSTS 等 HTTPS-only header 部署 https 後再開 -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <!--
          <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
          -->
        </customHeaders>
      </httpProtocol>

    </system.webServer>
  </location>

</configuration>
