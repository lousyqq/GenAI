<?xml version="1.0" encoding="utf-8"?>
<!--
  =========================================================================
  EQ Dashboard V2 — IIS web.config (唯讀 appsettings.json 專用標準版)
  =========================================================================
  ⭐️ 架構規範：
    1. 本系統在 IIS 部署環境下為【純 Windows 自動登入 / 模擬工號模式】。
    2. 已移除 web.config 內所有 Auth__ 覆寫變數，登入與權限 100% 只讀取主機上的
       appsettings.json (不會被 web.config 覆蓋)。
    3. ASPNETCORE_ENVIRONMENT 設為 Production，系統僅載入 appsettings.json。

  ⭐ IIS 驗證設定面板提醒 (必須手動調整，避免 HTTP 500.19)：
    因多數企業 IIS 鎖定 <security><authentication>，本 XML 不直接寫驗證標籤。
    請至 IIS Manager 點選此 APP → Authentication 面板手動開啟：
      ✓ Anonymous Authentication  = Enabled (讓網頁與靜態檔初次載入放行)
      ✓ Windows Authentication    = Enabled (讓後端 WhoAmI 取回真實 Windows 帳號)
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <aspNetCore processPath="dotnet"
                  arguments=".\GenAI.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">

        <environmentVariables>
          <!-- 環境名稱：Production 確保系統只讀取 appsettings.json -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />

          <!-- 
               Hosting__RequireHttps:
                 false → 允許 HTTP：Cookie 不帶 Secure 旗標 (內網 HTTP IIS 必備)
                 true  → 強制 HTTPS：若主機已上 SSL 憑證改為 true
          -->
          <environmentVariable name="Hosting__RequireHttps" value="false" />

          <!-- 
               ⚠️ 所有 Auth__、連線字串等覆寫變數已被乾淨移除！
               任何模擬帳號 (SimulatedWindowsAccount)、自動創建 (AutoProvisionWindowsAccounts)
               或覆寫權限 (AccountOverrides) 的異動，請直接於主機上的 appsettings.json 修改。
          -->
        </environmentVariables>
      </aspNetCore>

      <security>
        <!-- 單一請求 Body 大小上限 50 MB -->
        <requestFiltering>
          <requestLimits maxAllowedContentLength="52428800" />
        </requestFiltering>
      </security>

      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>

    </system.webServer>
  </location>
</configuration>
